<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CsWinRTApp.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CsWinRTApp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:CsWinRTApp.Models"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Grid HorizontalAlignment="Stretch" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              Padding="8,4" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
              BorderThickness="0,0,0,1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                <Button x:Name="BackButton" 
                        Click="BackButton_Click"
                        IsEnabled="False"
                        ToolTipService.ToolTip="返回上一级">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE72B;" FontSize="16"/>
                        <TextBlock Text="返回" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <TextBlock Grid.Column="1" 
                       Text="文件浏览器" 
                       VerticalAlignment="Center"
                       Margin="16,0,0,0"
                       FontSize="16"
                       FontWeight="SemiBold"/>
        </Grid>

        <Grid Grid.Row="1" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Name="LocationStack" Orientation="Vertical" HorizontalAlignment="Left" 
                        VerticalAlignment="Top"
                                Grid.Row="0"
                                Background="Transparent">
                <StackPanel  Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Button x:Name="myButton" Click="myButton_Click">选择目录</Button>
                </StackPanel>
            </StackPanel>
        </Grid>

        <GridView Grid.Row="2"  x:Name="ImageGridView" ItemsSource="{x:Bind Images, Mode=OneWay}" 
                  ContainerContentChanging="ImageGridView_ContainerContentChanging" 
                  ItemClick="ImageGridView_ItemClick"
                  SelectionChanged="ImageGridView_SelectionChanged"
                  IsItemClickEnabled="True"
                  SelectionMode="Single"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  SizeChanged="ImageGridView_SizeChanged">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:GeFileView">
                    <Border x:Name="ImageContainer" 
                            Background="LightGray" 
                            DoubleTapped="ImageContainer_DoubleTapped">
                        <!--<Image x:Name="ItemImage" Stretch="UniformToFill" />-->
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
        </GridView>

        <Grid Grid.Row="3" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
              Padding="8,4" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" 
              BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusBarText" 
                       Text="就绪" 
                       VerticalAlignment="Center"
                       FontSize="12"/>
        </Grid>
    </Grid>

</Page>
